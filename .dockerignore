__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
venv/
env/
*.env

# Ignore local dev artifacts
*.log
*.sqlite3
*.db
*.bak

# Ignore version control
.git/
.gitignore

# Ignore IDE/editor files
.vscode/
.idea/
*.swp
.DS_Store

# Ignore test files
tests/
