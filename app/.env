# ==============================================================================
# SYSGrow Configuration
# ==============================================================================


# ------------------------------------------------------------------------------
# AI SERVICE FEATURE TOGGLES
# ------------------------------------------------------------------------------

# Enable continuous background monitoring (checks every N seconds)
ENABLE_CONTINUOUS_MONITORING=True

# Enable personalized learning (user-specific recommendations)
ENABLE_PERSONALIZED_LEARNING=True

# Enable automated training data collection
ENABLE_TRAINING_DATA_COLLECTION=True

# Enable scheduled model retraining
ENABLE_AUTOMATED_RETRAINING=True

# Enable A/B testing for model versions
ENABLE_AB_TESTING=True

# Enable model drift detection
ENABLE_DRIFT_DETECTION=True

# Enable computer vision (requires camera + TensorFlow)
ENABLE_COMPUTER_VISION=False

# ------------------------------------------------------------------------------
# MONITORING CONFIGURATION
# ------------------------------------------------------------------------------

# How often to run monitoring checks (seconds)
# Raspberry Pi 3: 600 (10 min), Pi 4: 300 (5 min), Pi 5: 180 (3 min)
CONTINUOUS_MONITORING_INTERVAL=300

# Maximum insights to keep in memory per unit
MONITORING_MAX_INSIGHTS_PER_UNIT=50

# Minimum alert level for notifications: info, warning, critical
MONITORING_ALERT_THRESHOLD=warning

# ------------------------------------------------------------------------------
# STORAGE PATHS
# ------------------------------------------------------------------------------

# Directory for user environment profiles
PERSONALIZED_PROFILES_PATH=data/user_profiles

# Directory for training datasets
TRAINING_DATA_PATH=data/training

# Directory for ML models
MODELS_PATH=models

# ------------------------------------------------------------------------------
# TRAINING DATA COLLECTION
# ------------------------------------------------------------------------------

# Minimum data quality score (0-1) to include in training
TRAINING_DATA_MIN_QUALITY_SCORE=0.6

# Minimum sensor readings (hours) before using data
TRAINING_DATA_MIN_SENSOR_READINGS=24

# Cron schedule for data collection (2 AM daily)
TRAINING_DATA_COLLECTION_SCHEDULE=0 2 * * *

# Days to retain training data
TRAINING_DATA_RETENTION_DAYS=365

# ------------------------------------------------------------------------------
# MODEL CONFIGURATION
# ------------------------------------------------------------------------------

# Minimum samples required to train a model
MODEL_MIN_TRAINING_SAMPLES=100

# Fraction of data for validation (0.2 = 20%)
MODEL_VALIDATION_SPLIT=0.2

# Number of cross-validation folds
MODEL_CROSS_VALIDATION_FOLDS=5

# Cache predictions to reduce inference time
MODEL_CACHE_PREDICTIONS=True

# Seconds to cache predictions
MODEL_CACHE_TTL=300

# ------------------------------------------------------------------------------
# RETRAINING CONFIGURATION
# ------------------------------------------------------------------------------

# How often to check for retraining needs (seconds)
RETRAINING_CHECK_INTERVAL=3600

# Drift score threshold to trigger retraining (0.15 = 15%)
RETRAINING_DRIFT_THRESHOLD=0.15

# Minimum performance score (0.80 = 80% accuracy)
RETRAINING_PERFORMANCE_THRESHOLD=0.80

# Retraining schedules: daily, weekly, monthly, on_drift
RETRAINING_SCHEDULE_CLIMATE=weekly
RETRAINING_SCHEDULE_DISEASE=on_drift
RETRAINING_SCHEDULE_GROWTH=monthly

# Maximum concurrent retraining jobs (Raspberry Pi: keep at 1)
RETRAINING_MAX_CONCURRENT_JOBS=1

# ------------------------------------------------------------------------------
# DRIFT DETECTION
# ------------------------------------------------------------------------------

# Number of recent predictions to analyze
DRIFT_DETECTION_WINDOW_SIZE=100

# Alert if accuracy drops by this amount
DRIFT_DETECTION_ACCURACY_THRESHOLD=0.10

# Alert if average confidence falls below this
DRIFT_DETECTION_CONFIDENCE_THRESHOLD=0.60

# Alert if error rate exceeds this
DRIFT_DETECTION_ERROR_RATE_THRESHOLD=0.20

# ------------------------------------------------------------------------------
# PERFORMANCE SETTINGS (RASPBERRY PI OPTIMIZED)
# ------------------------------------------------------------------------------

# Maximum concurrent model predictions
# Pi 3: 1, Pi 4: 2, Pi 5: 3, Development: 5
MAX_CONCURRENT_PREDICTIONS=1

# Timeout for model predictions (seconds)
PREDICTION_TIMEOUT_SECONDS=30

# Use quantized models for faster inference
USE_MODEL_QUANTIZATION=True

# Enable GPU acceleration if available (Pi 5 only)
ENABLE_GPU_ACCELERATION=False

# ------------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# ------------------------------------------------------------------------------

# Send notifications for critical insights
NOTIFY_CRITICAL_INSIGHTS=True

# Disease risk level to trigger notification: moderate, high, critical
NOTIFY_DISEASE_RISK_THRESHOLD=high

# Send notifications for climate issues
NOTIFY_CLIMATE_ISSUES=True

# Send notifications for growth stage transitions
NOTIFY_GROWTH_STAGE_TRANSITIONS=True

# Minimum minutes between same notification (avoid spam)
NOTIFICATION_COOLDOWN_MINUTES=60

# ------------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ------------------------------------------------------------------------------

# Logging level for AI services: DEBUG, INFO, WARNING, ERROR
AI_LOG_LEVEL=INFO

# Log all model predictions
AI_LOG_PREDICTIONS=True

# Log detailed training metrics
AI_LOG_TRAINING_DETAILS=True

# Seconds between metrics export
AI_METRICS_EXPORT_INTERVAL=3600

# ------------------------------------------------------------------------------
# COMPUTER VISION (OPTIONAL)
# ------------------------------------------------------------------------------

# Model type: mobilenet_v2, efficientnet_b0, resnet50
CV_MODEL_TYPE=mobilenet_v2

# Inference device: cpu, gpu, tpu
CV_INFERENCE_DEVICE=cpu

# Input image size (width, height)
CV_IMAGE_WIDTH=224
CV_IMAGE_HEIGHT=224

# Minimum confidence for disease detection
CV_CONFIDENCE_THRESHOLD=0.7

# Seconds between automated captures (6 hours)
CV_CAPTURE_INTERVAL=21600

# ------------------------------------------------------------------------------
# PERSONALIZATION
# ------------------------------------------------------------------------------

# Minimum completed grows before personalized recommendations
PERSONALIZED_MIN_GROWS_FOR_PROFILE=3

# Minimum similarity score for matching similar growers
PERSONALIZED_SIMILARITY_THRESHOLD=0.6

# ------------------------------------------------------------------------------
# A/B TESTING
# ------------------------------------------------------------------------------

# Default traffic split (0.5 = 50/50)
AB_TESTING_DEFAULT_SPLIT_RATIO=0.5

# Minimum samples per variant before analysis
AB_TESTING_MIN_SAMPLES=100

# Statistical significance threshold (p-value)
AB_TESTING_SIGNIFICANCE_THRESHOLD=0.05

# Automatically promote winning model
AB_TESTING_AUTO_PROMOTE_WINNER=False

# ==============================================================================
# PLATFORM-SPECIFIC PRESETS
# ==============================================================================
# Uncomment one of these sections for your Raspberry Pi model
# or leave default for automatic detection

# --- Raspberry Pi 3 (Conservative) ---
# CONTINUOUS_MONITORING_INTERVAL=600
# MAX_CONCURRENT_PREDICTIONS=1
# USE_MODEL_QUANTIZATION=True
# ENABLE_GPU_ACCELERATION=False
# RETRAINING_CHECK_INTERVAL=7200

# --- Raspberry Pi 4 (Balanced) ---
# CONTINUOUS_MONITORING_INTERVAL=300
# MAX_CONCURRENT_PREDICTIONS=2
# USE_MODEL_QUANTIZATION=True
# ENABLE_GPU_ACCELERATION=False
# RETRAINING_CHECK_INTERVAL=3600

# --- Raspberry Pi 5 (Performance) ---
# CONTINUOUS_MONITORING_INTERVAL=180
# MAX_CONCURRENT_PREDICTIONS=3
# USE_MODEL_QUANTIZATION=False
# ENABLE_GPU_ACCELERATION=True
# RETRAINING_CHECK_INTERVAL=3600

# --- Development/Testing (Fast iteration) ---
# CONTINUOUS_MONITORING_INTERVAL=60
# MAX_CONCURRENT_PREDICTIONS=5
# USE_MODEL_QUANTIZATION=False
# ENABLE_GPU_ACCELERATION=True
# MODEL_CACHE_PREDICTIONS=False
# AI_LOG_LEVEL=DEBUG