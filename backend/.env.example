# ============================================================================
# SYSGrow Configuration Template
# ============================================================================
# Copy this file to .env and customize for your deployment.
# All values shown are defaults - only set values you want to change.
#
# Documentation: https://github.com/your-repo/sysgrow/docs/setup/INSTALLATION_GUIDE.md
# ============================================================================

# ==================== BASIC SETTINGS ====================
# Environment: development, production, testing
SYSGROW_ENV=development

# Enable debug mode (set to false for production on Pi)
SYSGROW_DEBUG=false

# Flask secret key - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SYSGROW_SECRET_KEY=your-secret-key-here-change-in-production

# ==================== SERVER ====================
# Host to bind to (0.0.0.0 for all interfaces)
SYSGROW_HOST=0.0.0.0

# Port to listen on
SYSGROW_PORT=5001

# SocketIO CORS origins (comma-separated or * for all)
SYSGROW_SOCKETIO_CORS=*

# ==================== DATABASE ====================
# SQLite database file path (relative to backend folder)
SYSGROW_DATABASE_PATH=database/sysgrow.db

# ==================== DATA RETENTION ====================
# Days to keep sensor readings before automatic pruning
# Lower values = smaller database, faster queries on Pi
SYSGROW_SENSOR_RETENTION_DAYS=30

# Days to keep actuator state history
SYSGROW_ACTUATOR_STATE_RETENTION_DAYS=90

# Days to keep alerts before auto-purge
SYSGROW_ALERT_RETENTION_DAYS=30

# Only purge resolved alerts (set to false to purge all old alerts)
SYSGROW_PURGE_RESOLVED_ONLY=true

# ==================== MQTT ====================
# Enable MQTT for ESP32 device communication
SYSGROW_ENABLE_MQTT=true

# MQTT broker hostname
SYSGROW_MQTT_HOST=localhost

# MQTT broker port
SYSGROW_MQTT_PORT=1883

# ==================== CACHING ====================
# Enable in-memory caching (improves performance, uses more RAM)
SYSGROW_CACHE_ENABLED=true

# Cache TTL in seconds
SYSGROW_CACHE_TTL=30

# Maximum cache entries (lower for Pi 3, higher for Pi 4)
SYSGROW_CACHE_MAXSIZE=128

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use WARNING or higher for production on Pi to reduce I/O
SYSGROW_LOG_LEVEL=INFO

# Audit log file path
SYSGROW_AUDIT_LOG_PATH=logs/audit.log

# Silence werkzeug HTTP request logs (recommended for Pi)
SYSGROW_SILENCE_WERKZEUG=true

# Silence SocketIO/EngineIO polling logs (recommended for Pi)
SYSGROW_SILENCE_SOCKETIO=true

# Enable verbose MQTT dispatch logging (for debugging only)
SYSGROW_LOG_MQTT_DISPATCH=false

# ==================== AI/ML SETTINGS ====================
# Enable continuous ML monitoring (pattern detection, anomalies)
ENABLE_CONTINUOUS_MONITORING=true

# Enable personalized learning (adapts to your grow patterns)
ENABLE_PERSONALIZED_LEARNING=true

# Enable training data collection for ML models
ENABLE_TRAINING_DATA_COLLECTION=true

# Enable automated model retraining (disable on Pi 3 for performance)
ENABLE_AUTOMATED_RETRAINING=false

# Monitoring interval in seconds
CONTINUOUS_MONITORING_INTERVAL=300

# Path to ML models directory
SYSGROW_MODELS_PATH=models

# ==================== RASPBERRY PI OPTIMIZATIONS ====================
# Maximum concurrent ML predictions (Pi 3: 1, Pi 4: 2, Pi 5: 3)
MAX_CONCURRENT_PREDICTIONS=2

# Use quantized models for faster inference on Pi
USE_MODEL_QUANTIZATION=true

# Enable GPU acceleration (Pi 5 only with Neural Network HAT)
ENABLE_GPU_ACCELERATION=false

# Event bus queue size (reduce for low memory Pi)
SYSGROW_EVENTBUS_QUEUE_SIZE=1024

# Event bus worker threads
SYSGROW_EVENTBUS_WORKER_COUNT=2

# ==================== API HEALTH MONITORING ====================
# Number of recent requests to track for health metrics
SYSGROW_API_HEALTH_WINDOW_SIZE=100

# Minimum samples before calculating health metrics
SYSGROW_API_HEALTH_MIN_SAMPLES=10

# Error rate threshold for "degraded" status (0.0-1.0)
SYSGROW_API_HEALTH_ERROR_RATE_DEGRADED=0.10

# Error rate threshold for "offline" status (0.0-1.0)
SYSGROW_API_HEALTH_ERROR_RATE_OFFLINE=0.50

# Average response time warning threshold (ms)
SYSGROW_API_HEALTH_AVG_RESPONSE_TIME_MS=2000

# Individual request slow threshold (ms)
SYSGROW_API_HEALTH_SLOW_REQUEST_MS=1000

# ==================== RATE LIMITING ====================
# Enable API rate limiting (protects Pi from overload)
SYSGROW_RATE_LIMIT_ENABLED=true

# Default requests per window
SYSGROW_RATE_LIMIT_DEFAULT=60

# Rate limit window in seconds
SYSGROW_RATE_LIMIT_WINDOW=60

# Optional: new variable names (preferred)
SYSGROW_RATE_LIMIT_DEFAULT_LIMIT=60
SYSGROW_RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# Burst limit (extra requests allowed)
SYSGROW_RATE_LIMIT_BURST=10

# ==================== NOTIFICATIONS ====================
# Enable notifications for critical insights
NOTIFY_CRITICAL_INSIGHTS=true

# Cooldown between similar notifications (minutes)
NOTIFICATION_COOLDOWN_MINUTES=60

# ==================== SECURITY ====================
# AES encryption key for WiFi credentials sent to ESP32 devices
# CRITICAL: Change this in production! Both backend and ESP32 must use same key.
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# Format: 32 hex characters (16 bytes)
SYSGROW_AES_KEY=your-32-char-hex-key-change-me

# ==================== HARDWARE ====================
# GPIO pin configuration (comma-separated: name:pin pairs)
# Example: SYSGROW_GPIO_PINS=relay1:17,relay2:27,fan:22

# I2C bus number (usually 1 on Pi)
SYSGROW_I2C_BUS=1

# ==================== DEVELOPMENT ONLY ====================
# These should NOT be set in production

# Skip database migrations on startup
# SYSGROW_SKIP_MIGRATIONS=false

# Enable hot reload (dev server only)
# FLASK_DEBUG=1

# Run with unsafe Werkzeug server (dev only)
# SYSGROW_ALLOW_UNSAFE_WERKZEUG=true
